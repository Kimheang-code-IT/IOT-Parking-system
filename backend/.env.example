# Local development (SQLite only)

DATABASE_URL=sqlite:///./data/iot_parking.db
# SEED_DEMO_DATA=true

CORS_ORIGINS=http://localhost:3000
API_BASE_URL=http://localhost:8000
RATE_LIMIT=120/minute
TOTAL_PARKING_SPOTS=200
RATE_PER_HOUR=2.00
MINIMUM_FEE=1.00
PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret

IOT_ENTRY_DEVICE_TOKEN=secret-entry-token
IOT_EXIT_DEVICE_TOKEN=secret-exit-token

# Mock QR by default; set false + merchant/key for PayWay sandbox
ABA_PAY_USE_MOCK=true
ABA_PAY_API_URL=https://checkout-sandbox.payway.com.kh
ABA_PAY_MERCHANT_ID=
ABA_PAY_API_KEY=
ABA_PAY_CALLBACK_URL=http://localhost:8000/api/payment/webhook
ABA_PAY_CURRENCY=USD
ABA_PAY_PAYMENT_OPTION=abapay_khqr
ABA_PAY_QR_TEMPLATE=template3_color
ABA_PAY_QR_LIFETIME_MINUTES=30
